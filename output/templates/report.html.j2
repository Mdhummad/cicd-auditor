<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>CI/CD Security Audit — {{ repo_name }}</title>
<meta name="description" content="Security audit report for {{ repo_url }} generated by cicd-auditor"/>
<style>
  :root {
    --bg: #0d1117; --bg2: #161b22; --bg3: #21262d;
    --border: #30363d; --text: #e6edf3; --muted: #8b949e;
    --critical: #ff453a; --high: #ff9f0a; --medium: #ffd60a; --low: #30d158;
    --accent: #58a6ff; --accent2: #bc8cff;
    --radius: 8px; --font: 'Inter', system-ui, sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: var(--font); font-size: 14px; line-height: 1.6; }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ── Layout ── */
  .page { max-width: 1200px; margin: 0 auto; padding: 24px 20px; }

  /* ── Header ── */
  header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 16px;
           background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius);
           padding: 24px 28px; margin-bottom: 24px; }
  .header-left h1 { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
  .header-left h1 span { color: var(--accent); }
  .header-meta { color: var(--muted); font-size: 12px; }
  .header-meta a { color: var(--accent); }
  .badge { display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px;
           border-radius: 999px; font-weight: 700; font-size: 14px; letter-spacing: 0.5px; }
  .badge-fail   { background: rgba(255,69,58,.15); color: var(--critical); border: 1px solid var(--critical); }
  .badge-warn   { background: rgba(255,159,10,.15); color: var(--high); border: 1px solid var(--high); }
  .badge-pass   { background: rgba(48,209,88,.15); color: var(--low); border: 1px solid var(--low); }
  .badge svg    { width: 16px; height: 16px; }

  /* ── Metrics row ── */
  .metrics { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 12px; margin-bottom: 24px; }
  .metric-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius);
                 padding: 16px 20px; text-align: center; }
  .metric-card .value { font-size: 32px; font-weight: 800; line-height: 1; margin-bottom: 4px; }
  .metric-card .label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.8px; color: var(--muted); }
  .c-total    { color: var(--text); }
  .c-critical { color: var(--critical); }
  .c-high     { color: var(--high); }
  .c-medium   { color: var(--medium); }
  .c-low      { color: var(--low); }

  /* ── Charts row ── */
  .charts { display: grid; grid-template-columns: 260px 1fr; gap: 16px; margin-bottom: 24px; }
  @media(max-width: 700px){ .charts { grid-template-columns: 1fr; } }
  .chart-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
  .chart-card h3 { font-size: 13px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.7px; margin-bottom: 16px; }
  .chart-wrap { position: relative; height: 200px; }

  /* ── Filter bar ── */
  .filter-bar { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
  .filter-btn { background: var(--bg3); border: 1px solid var(--border); color: var(--muted);
                padding: 5px 14px; border-radius: 999px; cursor: pointer; font-size: 12px; transition: all .2s; }
  .filter-btn:hover, .filter-btn.active { background: var(--accent); border-color: var(--accent); color: #000; font-weight: 600; }
  .search-box { flex: 1; min-width: 180px; background: var(--bg3); border: 1px solid var(--border);
                color: var(--text); padding: 5px 12px; border-radius: var(--radius); font-size: 12px; outline: none; }
  .search-box:focus { border-color: var(--accent); }

  /* ── Findings table ── */
  .findings-section { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; margin-bottom: 24px; }
  .findings-section h2 { padding: 16px 20px; font-size: 14px; border-bottom: 1px solid var(--border); }
  table { width: 100%; border-collapse: collapse; }
  th { background: var(--bg3); color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 0.7px;
       padding: 10px 16px; text-align: left; font-weight: 500; }
  td { padding: 10px 16px; border-top: 1px solid var(--border); vertical-align: top; }
  tr.finding-row { cursor: pointer; transition: background .15s; }
  tr.finding-row:hover { background: var(--bg3); }
  tr.detail-row { display: none; }
  tr.detail-row.open { display: table-row; }
  .detail-cell { padding: 0 16px 16px; }
  .detail-inner { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; }
  .detail-inner h4 { color: var(--muted); font-size: 11px; text-transform: uppercase; margin-bottom: 6px; }
  pre { background: #010409; border: 1px solid var(--border); border-radius: 6px; padding: 12px;
        overflow-x: auto; font-size: 12px; color: #c9d1d9; white-space: pre-wrap; word-break: break-all; }
  .copy-btn { display: inline-flex; align-items: center; gap: 4px; background: var(--bg3); border: 1px solid var(--border);
              color: var(--muted); padding: 3px 10px; border-radius: 4px; cursor: pointer; font-size: 11px; margin-top: 6px; }
  .copy-btn:hover { color: var(--text); border-color: var(--accent); }

  /* ── Severity badges ── */
  .sev { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 700; letter-spacing: 0.4px; }
  .sev-CRITICAL { background: rgba(255,69,58,.2); color: var(--critical); }
  .sev-HIGH     { background: rgba(255,159,10,.2); color: var(--high); }
  .sev-MEDIUM   { background: rgba(255,214,10,.2); color: var(--medium); }
  .sev-LOW      { background: rgba(48,209,88,.2); color: var(--low); }

  /* ── Type badges ── */
  .type { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; background: var(--bg3); color: var(--muted); }

  /* ── Score bar ── */
  .score-wrap { display: flex; align-items: center; gap: 6px; }
  .score-bar { flex: 1; height: 4px; background: var(--bg3); border-radius: 2px; overflow: hidden; }
  .score-fill { height: 100%; border-radius: 2px; }
  .score-val { font-size: 12px; font-weight: 700; min-width: 28px; }

  /* ── Empty state ── */
  .empty { text-align: center; padding: 60px 20px; color: var(--muted); }
  .empty .icon { font-size: 48px; margin-bottom: 12px; }

  /* ── Trend section ── */
  .trend-section { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; margin-bottom: 24px; }
  .trend-section h2 { font-size: 14px; margin-bottom: 16px; }

  /* ── Footer ── */
  footer { text-align: center; color: var(--muted); font-size: 12px; padding: 24px 0 8px; }

  /* ── Animations ── */
  @keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }
  .page { animation: fadeIn .3s ease; }
</style>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
</head>
<body>
<div class="page">

<!-- ── Header ── -->
<header>
  <div class="header-left">
    <h1>🔐 CI/CD Security Audit — <span>{{ repo_name }}</span></h1>
    <div class="header-meta">
      <a href="{{ repo_url }}" target="_blank">{{ repo_url }}</a>
      &nbsp;·&nbsp; Scanned {{ scanned_at }} UTC
      &nbsp;·&nbsp; cicd-auditor v1.0.0
    </div>
  </div>
  <div>
    {% if counts.CRITICAL > 0 %}
    <div class="badge badge-fail">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      FAIL — Critical Issues Found
    </div>
    {% elif counts.HIGH > 0 %}
    <div class="badge badge-warn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      WARNING — High Severity Issues
    </div>
    {% else %}
    <div class="badge badge-pass">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
      PASS — No Critical/High Issues
    </div>
    {% endif %}
  </div>
</header>

<!-- ── Metrics ── -->
<div class="metrics">
  <div class="metric-card"><div class="value c-total">{{ total }}</div><div class="label">Total Findings</div></div>
  <div class="metric-card"><div class="value c-critical">{{ counts.CRITICAL }}</div><div class="label">Critical</div></div>
  <div class="metric-card"><div class="value c-high">{{ counts.HIGH }}</div><div class="label">High</div></div>
  <div class="metric-card"><div class="value c-medium">{{ counts.MEDIUM }}</div><div class="label">Medium</div></div>
  <div class="metric-card"><div class="value c-low">{{ counts.LOW }}</div><div class="label">Low</div></div>
  <div class="metric-card"><div class="value" style="color:var(--accent2)">{{ type_counts.secret }}</div><div class="label">Secrets</div></div>
  <div class="metric-card"><div class="value" style="color:var(--accent)">{{ type_counts.misconfig }}</div><div class="label">Misconfigs</div></div>
  <div class="metric-card"><div class="value" style="color:var(--medium)">{{ type_counts.dependency }}</div><div class="label">CVEs</div></div>
</div>

<!-- ── Charts ── -->
<div class="charts">
  <div class="chart-card">
    <h3>Severity Distribution</h3>
    <div class="chart-wrap">
      <canvas id="donutChart"></canvas>
    </div>
  </div>
  {% if history %}
  <div class="chart-card">
    <h3>Critical Finding Trend (Last {{ history|length }} Scans)</h3>
    <div class="chart-wrap">
      <canvas id="trendChart"></canvas>
    </div>
  </div>
  {% else %}
  <div class="chart-card">
    <h3>Finding Type Breakdown</h3>
    <div class="chart-wrap">
      <canvas id="typeChart"></canvas>
    </div>
  </div>
  {% endif %}
</div>

<!-- ── Filter bar ── -->
<div class="filter-bar">
  <button class="filter-btn active" onclick="filterFindings('all', this)" id="btn-all">All ({{ total }})</button>
  <button class="filter-btn" onclick="filterFindings('secret', this)" id="btn-secret">🔑 Secrets ({{ type_counts.secret }})</button>
  <button class="filter-btn" onclick="filterFindings('misconfig', this)" id="btn-misconfig">⚙ Misconfigs ({{ type_counts.misconfig }})</button>
  <button class="filter-btn" onclick="filterFindings('dependency', this)" id="btn-dependency">📦 Dependencies ({{ type_counts.dependency }})</button>
  <input class="search-box" type="text" id="searchInput" placeholder="Search findings…" oninput="searchFindings(this.value)"/>
</div>

<!-- ── Findings table ── -->
<div class="findings-section">
  <h2>📋 All Findings</h2>
  {% if findings %}
  <table id="findingsTable">
    <thead>
      <tr>
        <th>Severity</th>
        <th>Type</th>
        <th>Rule</th>
        <th>File</th>
        <th>Line</th>
        <th>Risk Score</th>
      </tr>
    </thead>
    <tbody>
    {% for f in findings %}
    <tr class="finding-row" data-type="{{ f.finding_type }}" data-search="{{ (f.rule_name ~ ' ' ~ f.file_path ~ ' ' ~ f.description)|lower }}" onclick="toggleDetail({{ loop.index }})">
      <td><span class="sev sev-{{ f.severity }}">{{ f.severity }}</span></td>
      <td><span class="type">{{ f.finding_type }}</span></td>
      <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="{{ f.rule_name }}">
        <strong>{{ f.rule_id }}</strong><br/><span style="color:var(--muted);font-size:12px">{{ f.rule_name }}</span>
      </td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:monospace;font-size:12px" title="{{ f.file_path }}">
        {{ f.file_path }}
      </td>
      <td style="color:var(--muted)">{{ f.line_number or '—' }}</td>
      <td>
        <div class="score-wrap">
          <div class="score-bar"><div class="score-fill" style="width:{{ (f.risk_score / 10 * 100)|int }}%;background:{% if f.risk_score >= 9 %}var(--critical){% elif f.risk_score >= 7 %}var(--high){% elif f.risk_score >= 4 %}var(--medium){% else %}var(--low){% endif %}"></div></div>
          <span class="score-val" style="color:{% if f.risk_score >= 9 %}var(--critical){% elif f.risk_score >= 7 %}var(--high){% elif f.risk_score >= 4 %}var(--medium){% else %}var(--low){% endif %}">{{ "%.1f"|format(f.risk_score) }}</span>
        </div>
      </td>
    </tr>
    <tr class="detail-row" id="detail-{{ loop.index }}">
      <td colspan="6" class="detail-cell">
        <div class="detail-inner">
          <h4>Description</h4>
          <p style="margin-bottom:12px;color:var(--text)">{{ f.description }}</p>
          {% if f.fix_suggestion %}
          <h4>Remediation</h4>
          <pre id="fix-{{ loop.index }}">{{ f.fix_suggestion }}</pre>
          <button class="copy-btn" onclick="copyFix({{ loop.index }}, event)">📋 Copy Fix</button>
          {% endif %}
          {% if f.cve_reference is defined and f.cve_reference %}
          <p style="margin-top:10px;font-size:12px;color:var(--muted)">
            Reference: <a href="https://github.com/advisories?query={{ f.cve_reference }}" target="_blank">{{ f.cve_reference }}</a>
          </p>
          {% endif %}
        </div>
      </td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="empty">
    <div class="icon">✅</div>
    <p>No findings detected. Great security posture!</p>
  </div>
  {% endif %}
</div>

<!-- ── Footer ── -->
<footer>Generated by <strong>cicd-auditor</strong> · {{ scanned_at }} UTC · <a href="{{ repo_url }}" target="_blank">{{ repo_url }}</a></footer>

</div><!-- .page -->

<!-- ── Chart.js (CDN) ── -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// ── Charts ─────────────────────────────────────────────────
const COLORS = {
  CRITICAL: '#ff453a', HIGH: '#ff9f0a', MEDIUM: '#ffd60a', LOW: '#30d158'
};
Chart.defaults.color = '#8b949e';
Chart.defaults.borderColor = '#30363d';

// Donut
const donutCtx = document.getElementById('donutChart');
if (donutCtx) {
  new Chart(donutCtx, {
    type: 'doughnut',
    data: {
      labels: ['Critical', 'High', 'Medium', 'Low'],
      datasets: [{
        data: [{{ counts.CRITICAL }}, {{ counts.HIGH }}, {{ counts.MEDIUM }}, {{ counts.LOW }}],
        backgroundColor: [COLORS.CRITICAL, COLORS.HIGH, COLORS.MEDIUM, COLORS.LOW],
        borderWidth: 2, borderColor: '#161b22'
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, padding: 10 } } },
      cutout: '68%'
    }
  });
}

// Type chart
const typeCtx = document.getElementById('typeChart');
if (typeCtx) {
  new Chart(typeCtx, {
    type: 'bar',
    data: {
      labels: ['Secrets', 'Misconfigs', 'Dependencies'],
      datasets: [{
        label: 'Findings',
        data: [{{ type_counts.secret }}, {{ type_counts.misconfig }}, {{ type_counts.dependency }}],
        backgroundColor: ['#bc8cff', '#58a6ff', '#ffd60a'],
        borderRadius: 6, borderSkipped: false,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } }, x: { grid: { display: false } } }
    }
  });
}

{% if history %}
// Trend chart
const trendCtx = document.getElementById('trendChart');
if (trendCtx) {
  const labels = {{ history | map(attribute='scanned_at') | list | tojson }};
  const critData = {{ history | map(attribute='critical') | list | tojson }};
  new Chart(trendCtx, {
    type: 'line',
    data: {
      labels: labels,
      datasets: [{
        label: 'Critical Findings',
        data: critData,
        borderColor: COLORS.CRITICAL, backgroundColor: 'rgba(255,69,58,.1)',
        fill: true, tension: 0.4, pointRadius: 4,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: { y: { beginAtZero: true }, x: { ticks: { maxRotation: 45 } } }
    }
  });
}
{% endif %}

// ── Filter / Search ─────────────────────────────────────────
function filterFindings(type, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('tr.finding-row').forEach(row => {
    const show = type === 'all' || row.dataset.type === type;
    row.style.display = show ? '' : 'none';
    const id = row.getAttribute('onclick').match(/\d+/)[0];
    document.getElementById('detail-' + id).classList.remove('open');
  });
}

function searchFindings(q) {
  q = q.toLowerCase();
  document.querySelectorAll('tr.finding-row').forEach(row => {
    row.style.display = !q || row.dataset.search.includes(q) ? '' : 'none';
  });
}

// ── Toggle detail rows ──────────────────────────────────────
function toggleDetail(idx) {
  const row = document.getElementById('detail-' + idx);
  row.classList.toggle('open');
}

// ── Copy fix ────────────────────────────────────────────────
function copyFix(idx, e) {
  e.stopPropagation();
  const text = document.getElementById('fix-' + idx).textContent;
  navigator.clipboard.writeText(text).then(() => {
    const btn = e.target;
    btn.textContent = '✅ Copied!';
    setTimeout(() => { btn.textContent = '📋 Copy Fix'; }, 2000);
  });
}
</script>
</body>
</html>
